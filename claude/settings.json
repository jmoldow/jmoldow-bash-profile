      "Read(~/.lesskey)",
      "Read(~/.profile)",
      "Read(~/.vimrc)",
      "Read(~/.config/git/**)",
      "Read(~/.gitconfig)",
      "Write(~/.cache/**)",
      "Write(~/Library/Caches/**)",
      "Bash(jira issue view:*)",
