  "statusLine": {
    "type": "command",
    "command": "bash /Users/jordan/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "outputStyle": "default",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": false
    },
    "excludedCommands": [
      "docker",
      "git",
      "pants"
    ]
  },
  "alwaysThinkingEnabled": false,
  "autoMemoryEnabled": true,
  "effortLevel": "low"
