      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ping:*)",
      "Bash(jq:*)",
      "Bash(brew --prefix)",
      "Bash(git rev-parse --show-toplevel)",
      "Bash(git rev-parse --git-dir)",
      "Bash(git rev-parse:*)",
      "Bash(git branch --show-current:*)",
      "Bash(git diff:*)",
