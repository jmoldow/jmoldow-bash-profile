      "Bash(pants lint:*)",
      "Bash(pants fix:*)",
      "Bash(pants fmt:*)",
      "Bash(pants tailor:*)",
      "Bash(pants test:*)",
      "Bash(pants --no-dynamic-ui check:*)",
      "Bash(pants --no-dynamic-ui lint:*)",
      "Bash(pants --no-dynamic-ui fix:*)",
      "Bash(pants --no-dynamic-ui fmt:*)",
      "Bash(pants --no-dynamic-ui tailor:*)",
      "Bash(pants --no-dynamic-ui test:*)",
      "Bash(pants --no-dynamic-ui fmt fix lint:*)",
      "Bash(pants --no-dynamic-ui fmt fix lint check:*)",
      "Bash(pants --no-dynamic-ui fmt fix lint check test:*)",
      "Bash(pants --no-dynamic-ui tailor fmt fix lint check test:*)",
